*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Poppins',sans-serif;
background:linear-gradient(135deg,#ffd6e8,#ffe9f4,#fff6fb);
overflow:hidden;
height:100vh;
}

.page{
display:none;
justify-content:center;
align-items:center;
height:100vh;
padding:20px;
animation:fade .8s ease;
}

.page.active{
display:flex;
}

@keyframes fade{
from{
opacity:0;
transform:scale(.95);
}
to{
opacity:1;
transform:scale(1);
}
}

.card{

width:90%;
max-width:760px;

background:rgba(255,255,255,.75);

backdrop-filter:blur(18px);

border-radius:30px;

padding:35px;

text-align:center;

box-shadow:0 15px 40px rgba(255,105,180,.25);

border:3px solid rgba(255,255,255,.6);

position:relative;

overflow:hidden;

}

.card::before{

content:"❤️";

position:absolute;

font-size:150px;

opacity:.05;

top:-20px;

right:-10px;

transform:rotate(-20deg);

}

h1{

font-family:'Great Vibes',cursive;

font-size:58px;

color:#ff3f8e;

margin-bottom:15px;

}

h2{

font-size:28px;

color:#ff5b9c;

margin-bottom:20px;

}

p{

font-size:20px;

line-height:1.9;

color:#555;

margin-top:20px;

}

.from{

margin-top:30px;

font-size:23px;

color:#ff2e79;

font-weight:bold;

}

.mainPhoto{

width:270px;

height:270px;

object-fit:cover;

border-radius:25px;

border:7px solid white;

box-shadow:0 12px 35px rgba(255,105,180,.35);

margin:20px auto;

display:block;

transition:.5s;

}

.mainPhoto:hover{

transform:scale(1.05);

}

button{

margin-top:35px;

padding:15px 38px;

font-size:18px;

border:none;

border-radius:40px;

cursor:pointer;

background:linear-gradient(45deg,#ff4f8f,#ff8db6);

color:white;

font-weight:bold;

transition:.3s;

box-shadow:0 8px 20px rgba(255,105,180,.35);

}

button:hover{

transform:translateY(-4px) scale(1.05);

}

.hearts{

position:fixed;

left:0;

top:0;

width:100%;

height:100%;

pointer-events:none;

overflow:hidden;

}

.heart{

position:absolute;

color:#ff4f8f;

animation:float linear forwards;

opacity:.8;

}

@keyframes float{

0%{

transform:translateY(110vh) scale(.5);

opacity:0;

}

15%{

opacity:1;

}

100%{

transform:translateY(-120vh) rotate(360deg) scale(1.4);

opacity:0;

}

}

.sparkle{

position:absolute;

width:8px;

height:8px;

background:white;

border-radius:50%;

box-shadow:0 0 15px white;

animation:twinkle 2.5s infinite;

}

@keyframes twinkle{

0%,100%{

opacity:.2;

transform:scale(.5);

}

50%{

opacity:1;

transform:scale(1.5);

}

}

@media(max-width:768px){

h1{

font-size:44px;

}

h2{

font-size:22px;

}

p{

font-size:17px;

}

.mainPhoto{

width:210px;

height:210px;

}

button{

font-size:16px;

padding:13px 30px;

}

.card{

padding:25px;

}

}

const pages = document.querySelectorAll(".page");
let currentPage = 0;

function nextPage() {

    pages[currentPage].classList.remove("active");

    currentPage++;

    if (currentPage >= pages.length) {
        currentPage = pages.length - 1;
    }

    pages[currentPage].classList.add("active");

    if (currentPage === pages.length - 1) {
        heartExplosion();
    }

}

function createHeart() {

    const heart = document.createElement("div");

    heart.className = "heart";

    heart.innerHTML = ["❤","💖","💕","💗","💓"][Math.floor(Math.random()*5)];

    heart.style.left = Math.random()*100 + "vw";

    heart.style.fontSize = (18 + Math.random()*30) + "px";

    heart.style.animationDuration = (5 + Math.random()*5) + "s";

    document.querySelector(".hearts").appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },10000);

}

setInterval(createHeart,250);

function heartExplosion(){

    for(let i=0;i<80;i++){

        setTimeout(createHeart,i*50);

    }

}

for(let i=0;i<40;i++){

    const s=document.createElement("div");

    s.className="sparkle";

    s.style.left=Math.random()*100+"vw";

    s.style.top=Math.random()*100+"vh";

    s.style.animationDelay=Math.random()*3+"s";

    document.body.appendChild(s);

}

const music=document.getElementById("music");

document.body.addEventListener("click",()=>{

    music.play().catch(()=>{});

},{once:true});

const btn=document.createElement("button");

btn.innerHTML="🎵 Music";

btn.style.position="fixed";
btn.style.top="20px";
btn.style.right="20px";
btn.style.zIndex="999";
btn.style.padding="10px 18px";
btn.style.borderRadius="30px";

document.body.appendChild(btn);

btn.onclick=function(){

    if(music.paused){

        music.play();

        btn.innerHTML="⏸ Pause";

    }else{

        music.pause();

        btn.innerHTML="🎵 Music";

    }

};

/* ===========================
   PART 4 - Romantic Features
=========================== */

// Loading Screen
window.onload = function () {

    setTimeout(function () {

        const loader = document.getElementById("loader");

        if (loader) {
            loader.style.opacity = "0";

            setTimeout(function () {
                loader.style.display = "none";
            }, 1000);
        }

    }, 2500);

};

// Love Counter
const startDate = new Date("2025-01-01");

function updateCounter() {

    const now = new Date();

    const diff = now - startDate;

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));

    const counter = document.getElementById("days");

    if (counter) {
        counter.innerHTML = days + " Days Loving You ❤️";
    }

}

setInterval(updateCounter, 1000);

updateCounter();

// Typing Animation
const message =
"Sakshuu ❤️ You are my favourite person, my happiness, my peace and my forever. Thank you for making my life beautiful. I love you more than words can ever express. Forever Yours, Shubhii ❤️";

let index = 0;

function typingEffect() {

    const typing = document.getElementById("typing");

    if (!typing) return;

    if (index < message.length) {

        typing.innerHTML += message.charAt(index);

        index++;

        setTimeout(typingEffect, 55);

    }

}

setTimeout(typingEffect, 3500);

// Extra Heart Burst
function romanticExplosion() {

    for (let i = 0; i < 120; i++) {

        setTimeout(function () {

            if (typeof createHeart === "function") {
                createHeart();
            }

        }, i * 35);

    }

}

// Trigger on Last Page
const pagesList = document.querySelectorAll(".page");

const observer = setInterval(function () {

    if (pagesList.length > 0 &&
        pagesList[pagesList.length - 1].classList.contains("active")) {

        romanticExplosion();

        clearInterval(observer);

    }

}, 500);

/* =========================================
        PART 5 - PREMIUM LOVE EFFECTS
=========================================*/

// 🌹 Falling Rose Petals
const petals = ["🌹","🌸","💮","🌺","💖"];

function createPetal(){

    const petal=document.createElement("div");

    petal.innerHTML=petals[Math.floor(Math.random()*petals.length)];

    petal.style.position="fixed";
    petal.style.left=Math.random()*100+"vw";
    petal.style.top="-50px";
    petal.style.fontSize=(20+Math.random()*25)+"px";
    petal.style.pointerEvents="none";
    petal.style.zIndex="999";

    const duration=6+Math.random()*5;

    petal.animate([
        {
            transform:"translateY(-20px) rotate(0deg)"
        },
        {
            transform:`translate(${Math.random()*200-100}px,110vh) rotate(${720+Math.random()*360}deg)`
        }
    ],{
        duration:duration*1000,
        easing:"linear"
    });

    document.body.appendChild(petal);

    setTimeout(()=>{
        petal.remove();
    },duration*1000);

}

setInterval(createPetal,450);



// ❤️ Heart Cursor Trail

document.addEventListener("mousemove",function(e){

    const heart=document.createElement("div");

    heart.innerHTML="❤️";

    heart.style.position="fixed";
    heart.style.left=e.clientX+"px";
    heart.style.top=e.clientY+"px";
    heart.style.fontSize="18px";
    heart.style.pointerEvents="none";
    heart.style.zIndex="9999";

    document.body.appendChild(heart);

    heart.animate([
        {
            opacity:1,
            transform:"translateY(0px) scale(1)"
        },
        {
            opacity:0,
            transform:"translateY(-45px) scale(2)"
        }
    ],{
        duration:900
    });

    setTimeout(()=>{
        heart.remove();
    },900);

});




// 🎆 Fireworks on Last Page

function fireworks(){

    for(let i=0;i<70;i++){

        const spark=document.createElement("div");

        spark.innerHTML="✨";

        spark.style.position="fixed";
        spark.style.left="50%";
        spark.style.top="50%";
        spark.style.fontSize="20px";
        spark.style.pointerEvents="none";
        spark.style.zIndex="9999";

        const x=(Math.random()-0.5)*900;
        const y=(Math.random()-0.5)*700;

        spark.animate([
            {
                transform:"translate(0,0)",
                opacity:1
            },
            {
                transform:`translate(${x}px,${y}px)`,
                opacity:0
            }
        ],{
            duration:1800,
            easing:"ease-out"
        });

        document.body.appendChild(spark);

        setTimeout(()=>{
            spark.remove();
        },1800);

    }

}




